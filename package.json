{
  "name": "linkml-scala-action",
  "version": "0.9.2",
  "private": true,
  "type": "module",
  "description": "GitHub Action to validate and generate from LinkML schemas using linkml-scala. Pure Node.js.",
  "license": "Apache-2.0",
  "author": "NeverBlink (https://neverblink.eu)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NeverBlink-OSS/linkml-scala-action.git"
  },
  "scripts": {
    "build": "esbuild src/index.js --bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.cjs",
    "test": "node test/run.mjs",
    "coverage": "cross-env ACTION_ENTRY=src/index.js c8 node test/run.mjs"
  },
  "c8": {
    "include": ["src/**"],
    "reporter": ["text", "text-summary"]
  },
  "dependencies": {
    "@neverblink/linkml": "0.9.2"
  },
  "devDependencies": {
    "c8": "^10.1.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.23.0"
  }
}
